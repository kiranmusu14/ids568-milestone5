# LLM Inference Server — environment variable template
# Copy to .env and adjust values as needed.
# All variables use the LLM_ prefix (see src/config.py).

# Batching
LLM_MAX_BATCH_SIZE=8
LLM_BATCH_TIMEOUT_MS=50.0

# Caching
LLM_CACHE_TTL_SECONDS=300.0
LLM_CACHE_MAX_ENTRIES=1000

# Simulated model
LLM_MODEL_NAME=simulated-llm-7b
LLM_BASE_INFERENCE_LATENCY_MS=100.0
LLM_PER_REQUEST_LATENCY_MS=30.0
LLM_BATCH_AMORTIZATION_FACTOR=0.4

# Server
LLM_HOST=0.0.0.0
LLM_PORT=8000
LLM_LOG_LEVEL=info
